    {
      "title": "Have / Don't have: 有 / 没有",
      "pattern": "我有钱。/ 我没有钱。",
      "note": "有 (yǒu) = to have. Its negative is 没有 (méiyǒu) — NOT 不有. This is the only verb negated with 没 in its regular form."
    },
    {
      "title": "Measure words: 个, 件, 本",
      "pattern": "一个苹果 / 两件衣服 / 三本书",
      "note": "Chinese uses measure words between numbers and nouns. 个 is general. 件 (jiàn) for clothes/matters. 本 (běn) for books. Never just '一书'!"
    },
    {
      "title": "Comparison: A 比 B + adj",
      "pattern": "这件衣服比那件贵。",
      "note": "比 (bǐ) = than. Structure: A 比 B + adjective. To say 'not as … as': A 没有 B + adj. No 很 with 比!"
    }
  ],
