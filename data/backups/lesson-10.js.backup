  "grammar": [
    {
      "title": "Expressing likes: 喜欢 + verb/noun",
      "pattern": "我喜欢看电影。/ 我喜欢音乐。",
      "note": "喜欢 (xǐhuan) = to like. Follow with a verb or noun. 爱 (ài) = to love (stronger). 我爱唱歌 = I love singing. No extra particle needed between 喜欢 and the verb."
    },
    {
      "title": "Mild negation: 不太 + adj/verb",
      "pattern": "我不太喜欢运动。",
      "note": "不太 (bú tài) = not very / not really. Softer than 不. 不太好 = not very good. 不太喜欢 = don't really like. Much more natural than a blunt 不喜欢 in conversation."
    },
    {
      "title": "也 and 都 with multiple subjects",
      "pattern": "我喜欢音乐，他也喜欢。/ 我们都喜欢。",
      "note": "也 (yě) = also (for one additional subject). 都 (dōu) = all/both (for multiple subjects together). 也 and 都 always come BEFORE the verb."
    }
  ],
